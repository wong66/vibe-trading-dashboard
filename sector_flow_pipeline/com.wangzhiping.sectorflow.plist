    <key>RunAtLoad</key>
    <boolean>false</boolean>

    <key>WorkingDirectory</key>
    <string>/Users/wangzhiping/Claude/大A投研看板/sector_flow_pipeline</string>

    <key>StandardOutPath</key>
    <string>/Users/wangzhiping/Claude/大A投研看板/sector_flow_pipeline/logs/collector.out.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/wangzhiping/Claude/大A投研看板/sector_flow_pipeline/logs/collector.err.log</string>
</dict>
</plist>
