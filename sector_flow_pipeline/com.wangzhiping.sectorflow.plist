<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.wangzhiping.sectorflow</string>

    <key>ProgramArguments</key>
    <array>
        <string>/opt/anaconda3/bin/python3</string>
        <string>/Users/wangzhiping/Claude/大A投研看板/sector_flow_pipeline/collector.py</string>
        <string>--once</string>
    </array>

    <!-- 每 15 分钟跑一次; collector 内部已做交易时段守卫, 非交易时段自动跳过 -->
